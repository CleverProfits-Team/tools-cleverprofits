# ─────────────────────────────────────────────────────────────────────────────
# CleverProfits Tools Platform — Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

# Public URL of this app. Used for OAuth redirect URIs and internal URL generation.
#
# TWO-PHASE DEPLOYMENT:
#   Phase 1 — Initial Railway deploy (before custom domain):
#     Set to your Railway-assigned URL, e.g.:
#     NEXTAUTH_URL=https://tools-cleverprofits-production.up.railway.app
#     Also add this URL to Google OAuth → Authorized redirect URIs:
#       https://<railway-url>/api/auth/callback/google
#
#   Phase 2 — After custom domain (tools.cleverprofits.com) is live:
#     Update to: NEXTAUTH_URL=https://tools.cleverprofits.com
#     Add the new URL to Google OAuth → Authorized redirect URIs:
#       https://tools.cleverprofits.com/api/auth/callback/google
#     (Keep the Railway URL in Google OAuth during the transition period)
#
# Local dev:
NEXTAUTH_URL=http://localhost:3000

# Random secret for signing NextAuth JWT tokens and session cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/tools_cleverprofits?sslmode=require

# ── Google OAuth ──────────────────────────────────────────────────────────────

# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must include: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack ─────────────────────────────────────────────────────────────────────

# Incoming Webhook URL from a Slack App.
# Create at: https://api.slack.com/apps → Your App → Incoming Webhooks
# Leave empty to disable Slack notifications (the app will still work).
SLACK_WEBHOOK_URL=

# ── Notion ────────────────────────────────────────────────────────────────────

# Internal Notion integration token.
# Create at: https://www.notion.so/my-integrations
# Leave empty to disable Notion sync (the app will still work).
NOTION_API_KEY=

# ID of the Notion database where tool records will be created.
# Found in the database URL: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=
