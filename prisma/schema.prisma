generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// Created on first sign-in (upsert in next-auth signIn callback).
// Role defaults to VIEWER; elevated roles assigned by ADMIN / SUPER_ADMIN.
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  role      Role       @default(VIEWER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tool
// Every internal tool registered on the platform.
// ─────────────────────────────────────────────────────────────────────────────
model Tool {
  id          String      @id @default(cuid())

  // Identity
  name        String
  slug        String      @unique  // URL key: tools.cleverprofits.com/[slug]
  externalUrl String                // Actual upstream URL (e.g. Railway)
  description String?
  notes       String?

  // Ownership & classification
  team             String?
  ownerName        String?  // Product owner — responsible for the tool's purpose & direction
  ownerEmail       String?
  maintainerName   String?  // Technical maintainer — responsible for keeping it running
  maintainerEmail  String?
  accessLevel AccessLevel @default(INTERNAL)
  status      ToolStatus  @default(PENDING)

  // Rejection
  rejectionReason String?

  // Audit (Phase 8 will migrate these columns to a User FK)
  createdByName  String
  createdByEmail String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // ── Smart Registration ────────────────────────────────────────────────────
  githubRepoUrl  String?
  isExperimental Boolean @default(false)

  // ── AI Analysis pipeline ──────────────────────────────────────────────────
  // Tracks the state of the async analysis job independently of governance status.
  analysisStatus   AnalysisStatus @default(PENDING_ANALYSIS)
  analysisError    String?
  lastAnalyzedAt   DateTime?
  analysisSnapshot String?        @db.Text // truncated raw content fed to the AI

  // ── AI-generated profile ──────────────────────────────────────────────────
  // All fields are nullable and always editable — they are suggestions, not locks.
  aiTitle          String?
  aiSummary        String?        // one sentence
  aiDescription    String?        @db.Text
  aiObjective      String?
  aiSuggestedUsers String?
  aiCategory       String?
  aiTechStack      String?
  aiFrameworkGuess String?
  aiConfidence     Float?         // 0.0 – 1.0
  aiOverlapWarnings Json?         // String[] of tool names flagged as overlapping

  // Relations
  tags     Tag[]         @relation("ToolTags")
  hits     ProxyHit[]
  versions ToolVersion[]

  @@map("tools")
}

// ─────────────────────────────────────────────────────────────────────────────
// Invitation
// Created by admins to invite users with a specific role.
// ─────────────────────────────────────────────────────────────────────────────
model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      Role
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  USED
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN  // Full control + can assign/revoke ADMIN role
  ADMIN        // Can approve tools and manage non-admin users
  BUILDER      // Can register tools; cannot approve own submissions
  VIEWER       // Read-only access to approved tools (default)
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AccessLevel {
  INTERNAL     // Visible to all authenticated CleverProfits users
  RESTRICTED   // Specific teams only (enforced manually in V1; RBAC in V2)
  LEADERSHIP   // Leadership team only
}

enum ToolStatus {
  DRAFT     // Being registered via Smart Registration; not yet submitted
  ACTIVE    // Proxy routing live
  PENDING   // Registered but not yet approved / deployed
  ARCHIVED  // Soft-deleted; proxy returns 503
  REJECTED  // Rejected by admin with a reason
}

enum AnalysisStatus {
  PENDING_ANALYSIS   // Tool created, analysis not yet started
  ANALYZING          // Analysis pipeline is running
  ANALYSIS_COMPLETE  // AI results ready; tool awaiting user review
  ANALYSIS_FAILED    // Error occurred; user can retry or fill in manually
}

// ─────────────────────────────────────────────────────────────────────────────
// Tag
// Canonical tags for organizing tools. Many-to-many with Tool.
// ─────────────────────────────────────────────────────────────────────────────
model Tag {
  id    String @id @default(cuid())
  name  String @unique
  tools Tool[] @relation("ToolTags")

  @@map("tags")
}

// ─────────────────────────────────────────────────────────────────────────────
// ProxyHit
// One row per proxied request — used for usage analytics.
// ─────────────────────────────────────────────────────────────────────────────
model ProxyHit {
  id         String   @id @default(cuid())
  toolId     String
  toolSlug   String
  toolName   String
  method     String
  path       String   @db.VarChar(2048)
  statusCode Int
  durationMs Int
  createdAt  DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([createdAt(sort: Desc)])
  @@map("proxy_hits")
}

// ─────────────────────────────────────────────────────────────────────────────
// ToolVersion
// Immutable changelog entry created on every tool update.
// ─────────────────────────────────────────────────────────────────────────────
model ToolVersion {
  id             String   @id @default(cuid())
  toolId         String
  version        Int
  changes        Json     // { fieldName: { from: any, to: any } }
  changedByEmail String
  changedByName  String
  createdAt      DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, version])
  @@map("tool_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Favorite
// Per-user tool bookmarks for quick access.
// ─────────────────────────────────────────────────────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userEmail String
  toolId    String
  createdAt DateTime @default(now())

  @@unique([userEmail, toolId])
  @@index([userEmail])
  @@map("favorites")
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog
// Immutable record of every significant action on the platform.
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // TOOL_REGISTERED | TOOL_APPROVED | TOOL_REJECTED | TOOL_ARCHIVED | TOOL_RESTORED | ROLE_CHANGED | USER_SUSPENDED | USER_ACTIVATED
  actorEmail  String
  actorName   String
  toolId      String?
  toolName    String?
  targetEmail String?  // for user-targeted actions
  detail      String?  // e.g. rejection reason, "VIEWER → ADMIN"
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
