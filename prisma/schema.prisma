generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// Created on first sign-in (upsert in next-auth signIn callback).
// Role defaults to VIEWER; elevated roles assigned by ADMIN / SUPER_ADMIN.
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  role      Role       @default(VIEWER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tool
// Every internal tool registered on the platform.
// ─────────────────────────────────────────────────────────────────────────────
model Tool {
  id          String      @id @default(cuid())

  // Identity
  name        String
  slug        String      @unique  // URL key: tools.cleverprofits.com/[slug]
  externalUrl String                // Actual upstream URL (e.g. Railway)
  description String?
  notes       String?

  // Ownership & classification
  team        String?
  accessLevel AccessLevel @default(INTERNAL)
  status      ToolStatus  @default(PENDING)

  // Rejection
  rejectionReason String?

  // Audit (Phase 8 will migrate these columns to a User FK)
  createdByName  String
  createdByEmail String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("tools")
}

// ─────────────────────────────────────────────────────────────────────────────
// Invitation
// Created by admins to invite users with a specific role.
// ─────────────────────────────────────────────────────────────────────────────
model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      Role
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  USED
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN  // Full control + can assign/revoke ADMIN role
  ADMIN        // Can approve tools and manage non-admin users
  BUILDER      // Can register tools; cannot approve own submissions
  VIEWER       // Read-only access to approved tools (default)
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AccessLevel {
  INTERNAL     // Visible to all authenticated CleverProfits users
  RESTRICTED   // Specific teams only (enforced manually in V1; RBAC in V2)
  LEADERSHIP   // Leadership team only
}

enum ToolStatus {
  ACTIVE    // Proxy routing live
  PENDING   // Registered but not yet approved / deployed
  ARCHIVED  // Soft-deleted; proxy returns 503
  REJECTED  // Rejected by admin with a reason
}
